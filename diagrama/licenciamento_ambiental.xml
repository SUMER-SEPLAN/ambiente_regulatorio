        <mxCell id="D4aP_P9Au8OuQ_5HPQlE-27" parent="1" style="shape=hexagon;perimeter=hexagonPerimeter2;whiteSpace=wrap;html=1;fixedSize=1;" value="&#xa;&#xa;&#xa;&lt;p class=&quot;MsoNormal&quot; style=&quot;margin-left:-35.45pt&quot;&gt;&lt;span style=&quot;background:yellow;&#xa;mso-highlight:yellow&quot;&gt;São instrumentos técnicos exigidos no licenciamento&#xa;ambiental que avaliam os impactos de empreendimentos de energia e orientam a&#xa;tomada de decisão quanto à sua viabilidade ambiental.&lt;/span&gt;&lt;/p&gt;&#xa;&#xa;&#xa;&#xa;&#xa;&#xa;" vertex="1">
