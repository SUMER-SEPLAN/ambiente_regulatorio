        <mxCell id="D4aP_P9Au8OuQ_5HPQlE-9" parent="1" style="shape=hexagon;perimeter=hexagonPerimeter2;whiteSpace=wrap;html=1;fixedSize=1;" value="&lt;span style=&quot;font-size:12.0pt;line-height:115%;&lt;br/&gt;font-family:&amp;quot;Calibri&amp;quot;,sans-serif;mso-ascii-theme-font:minor-latin;mso-fareast-font-family:&lt;br/&gt;Calibri;mso-fareast-theme-font:minor-latin;mso-hansi-theme-font:minor-latin;&lt;br/&gt;mso-bidi-font-family:&amp;quot;Times New Roman&amp;quot;;mso-bidi-theme-font:minor-bidi;&lt;br/&gt;mso-ansi-language:PT-BR;mso-fareast-language:EN-US;mso-bidi-language:AR-SA&quot;&gt;Registro&lt;br/&gt;público eletrônico de abrangência nacional, obrigatório para todos os imóveis&lt;br/&gt;rurais, que integra as informações ambientais das propriedades referentes à&lt;br/&gt;situação das APPs, Reserva Legal, remanescentes de vegetação nativa e áreas&lt;br/&gt;consolidadas. É pré-requisito para acesso ao Programa de Regularização&lt;br/&gt;Ambiental (PRA) e para obtenção de financiamentos e benefícios agrícolas.&lt;/span&gt;" vertex="1">
          <mxGeometry height="80" width="120" x="336" y="-910" as="geometry" />
        </mxCell>
        <mxCell id="D4aP_P9Au8OuQ_5HPQlE-13" edge="1" parent="1" source="D4aP_P9Au8OuQ_5HPQlE-8" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=0.013;entryY=0.68;entryDx=0;entryDy=0;entryPerimeter=0;" target="Vo16OP1xxp4yjsuZDWTS-130">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="D4aP_P9Au8OuQ_5HPQlE-18" edge="1" parent="1" source="D4aP_P9Au8OuQ_5HPQlE-15" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" target="Vo16OP1xxp4yjsuZDWTS-131">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="D4aP_P9Au8OuQ_5HPQlE-15" parent="1" style="shape=hexagon;perimeter=hexagonPerimeter2;whiteSpace=wrap;html=1;fixedSize=1;" value="&#xa;&lt;span style=&quot;font-size:12.0pt;line-height:115%;&#xa;font-family:&amp;quot;Calibri&amp;quot;,sans-serif;mso-ascii-theme-font:minor-latin;mso-fareast-font-family:&#xa;Calibri;mso-fareast-theme-font:minor-latin;mso-hansi-theme-font:minor-latin;&#xa;mso-bidi-font-family:&amp;quot;Times New Roman&amp;quot;;mso-bidi-theme-font:minor-bidi;&#xa;mso-ansi-language:PT-BR;mso-fareast-language:EN-US;mso-bidi-language:AR-SA&quot;&gt;Os&#xa;procedimentos de inscrição no CAR devem considerar os limites georreferenciados&#xa;do imóvel rural, as Áreas de Preservação Permanente, a Reserva Legal e as áreas&#xa;consolidadas; o órgão estadual gestor será responsável pela análise e validação&#xa;das informações declaradas pelo proprietário; ficará a encargo do proprietário&#xa;rural a regularidade cadastral e, quando necessário, a adesão ao &lt;b&gt;PRA&lt;/b&gt; - Programa&#xa;de Regularização Ambiental, para adequação dos passivos ambientais&#xa;identificados. &lt;b&gt;SICAR&lt;/b&gt;: Sistema de Cadastro Ambiental Rural é o sistema&#xa;eletrônico por meio do qual é realizado o cadastro imóvel.&lt;/span&gt;&#xa;&#xa;&#xa;&#xa;" vertex="1">
          <mxGeometry height="80" width="120" x="300" y="-700" as="geometry" />
        </mxCell>
        <mxCell id="D4aP_P9Au8OuQ_5HPQlE-19" parent="1" style="shape=hexagon;perimeter=hexagonPerimeter2;whiteSpace=wrap;html=1;fixedSize=1;" value="&lt;span style=&quot;font-size:12.0pt;line-height:115%;&lt;br/&gt;font-family:&amp;quot;Calibri&amp;quot;,sans-serif;mso-ascii-theme-font:minor-latin;mso-fareast-font-family:&lt;br/&gt;Calibri;mso-fareast-theme-font:minor-latin;mso-hansi-theme-font:minor-latin;&lt;br/&gt;mso-bidi-font-family:&amp;quot;Times New Roman&amp;quot;;mso-bidi-theme-font:minor-bidi;&lt;br/&gt;mso-ansi-language:PT-BR;mso-fareast-language:EN-US;mso-bidi-language:AR-SA&quot;&gt;O&lt;br/&gt;registro do CAR, tem aporte na legislação federal: Código florestal nº&lt;br/&gt;12.651/12; Mata Atlântica nº 11.428/06; LGLA nº 15.190/25; Res. 369/06; Port.&lt;br/&gt;MMA 443/14&lt;/span&gt;" vertex="1">
          <mxGeometry height="80" width="120" x="414" y="-490" as="geometry" />
        </mxCell>
        <mxCell id="D4aP_P9Au8OuQ_5HPQlE-20" edge="1" parent="1" source="D4aP_P9Au8OuQ_5HPQlE-19" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=1.003;entryY=0.648;entryDx=0;entryDy=0;entryPerimeter=0;" target="Vo16OP1xxp4yjsuZDWTS-132">
