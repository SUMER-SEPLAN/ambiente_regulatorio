        <mxCell id="Vo16OP1xxp4yjsuZDWTS-30" parent="1" style="shape=hexagon;perimeter=hexagonPerimeter2;whiteSpace=wrap;html=1;fixedSize=1;" value="&lt;p class=&quot;MsoNormal&quot; style=&quot;text-align:justify&quot;&gt;&lt;font style=&quot;font-size: 9px;&quot;&gt;Vinculado à Presidência da&lt;br/&gt;República, com a atribuição de propor ao Presidente da República políticas&lt;br/&gt;nacionais e medidas para o setor.&lt;/font&gt;&lt;/p&gt;" vertex="1">
